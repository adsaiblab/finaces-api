# .env.production.example — template pour la production, à copier en .env.production sur le VPS
# NE JAMAIS VERSIONNER .env.production — ce fichier exemple est la référence.
# Générés avec : openssl rand -hex 32

ENVIRONMENT=production
SECRET_KEY=REPLACE_WITH_MIN_64_CHAR_RANDOM_SECRET

# PostgreSQL — doit correspondre aux variables du service `db` dans docker-compose.prod.yml
POSTGRES_DB=finaces_prod
POSTGRES_USER=finaces
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://finaces:REPLACE_WITH_STRONG_PASSWORD@db:5432/finaces_prod

# Redis — hostname = nom du service Docker
REDIS_URL=redis://redis:6379/0

# Sentry (optionnel)
SENTRY_DSN=
