# .env.example — template pour les développeurs, jamais de secrets réels
# Copiez ce fichier en .env et adaptez les valeurs à votre environnement local.

ENVIRONMENT=development
SECRET_KEY=change-me-in-production-min-32-chars
DATABASE_URL=postgresql+asyncpg://finaces:password@localhost:5432/finaces_dev
REDIS_URL=redis://localhost:6379/0
SENTRY_DSN=
